---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Stefan Malinovic — Senior Level & Game Designer',
  description = 'Portfolio of Stefan Malinovic — Senior / Lead Level & Game Designer. Eight years across AAA, VR and open-world at Ubisoft, RedSixteen, PlayStudios and MILC.',
  ogImage = '/assets/brand/og-image.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://steppenvvolf.github.io');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, canonicalURL.origin)} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, canonicalURL.origin)} />

    <link rel="icon" type="image/png" href="/assets/brand/favicon-source.png" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/assets/brand/favicon-source.png" />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
