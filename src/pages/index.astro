---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Stefan Malinovic — Phase 1 Scaffold">
  <main>

    <!-- ── Identity strip ─────────────────────────────────────────────── -->
    <header class="scaffold-header">
      <div class="logo-mark">SM<span>.</span></div>
      <nav>
        <a href="#">WORK</a>
        <a href="#">PROCESS</a>
        <a href="#">ABOUT</a>
        <a href="#" class="nav-contact">CONTACT</a>
      </nav>
    </header>

    <!-- ── Scaffold content ───────────────────────────────────────────── -->
    <div class="container">

      <!-- Phase badge -->
      <div class="phase-badge">
        <span>PHASE 1 SCAFFOLD ✓</span>
      </div>

      <!-- Hero name — Anton -->
      <section class="specimen-block">
        <div class="specimen-label">FONT: ANTON · HERO DISPLAY</div>
        <h1 class="hero-name">
          STEFAN<br/>MALINOVIC<span class="accent-dot">.</span>
        </h1>
        <p class="hero-sub">Senior / Lead Level &amp; Game Designer · AAA · VR · Open-World</p>
      </section>

      <!-- Section title — Pirata One -->
      <section class="specimen-block">
        <div class="specimen-label">FONT: PIRATA ONE · SECTION TITLES</div>
        <h2 class="gothic-title">Featured Work</h2>
        <h2 class="gothic-title">Design Philosophy</h2>
        <h2 class="gothic-title">My Process</h2>
      </section>

      <!-- Oswald labels -->
      <section class="specimen-block">
        <div class="specimen-label">FONT: OSWALD · UI LABELS / NAV / METADATA</div>
        <p class="ui-label">LEVEL DESIGNER · UE5 · 2024–PRESENT</p>
        <p class="ui-label" style="font-weight:500;letter-spacing:0.18em;">UBISOFT · AAA · OPEN-WORLD</p>
        <p class="ui-label" style="font-weight:400;">DOWNLOAD CV · VIEW THE WORK · CONTACT</p>
      </section>

      <!-- Bangers impact -->
      <section class="specimen-block">
        <div class="specimen-label">FONT: BANGERS · ACTION CALLOUTS</div>
        <p class="impact-text">VROOM! BANG! BUILT IN UE5!</p>
      </section>

      <!-- Comic Neue speech bubble -->
      <section class="specimen-block">
        <div class="specimen-label">FONT: COMIC NEUE · SPEECH BUBBLES</div>
        <div class="speech-bubble-demo">
          <p class="bubble-text">"Let's build worlds — shall we?"</p>
          <div class="bubble-tail"></div>
        </div>
      </section>

      <!-- Inter body -->
      <section class="specimen-block">
        <div class="specimen-label">FONT: INTER · LONG-FORM BODY</div>
        <p class="body-text">
          A space should teach the player without a single line of instruction.
          That's the belief behind every zone I've designed — from open-world
          Landmarks in Riders Republic to tight VR mission corridors in AC Nexus.
        </p>
      </section>

      <!-- Color swatches -->
      <section class="specimen-block">
        <div class="specimen-label">COLOR PALETTE · 6 UI TOKENS</div>
        <div class="swatch-row">
          <div class="swatch" style="background:#0E0D0D;border:2px solid #F5E8D0;">
            <span>Ink</span><code>#0E0D0D</code>
          </div>
          <div class="swatch" style="background:#1B1918;">
            <span>Panel</span><code>#1B1918</code>
          </div>
          <div class="swatch" style="background:#F5E8D0;color:#0E0D0D;">
            <span>Cream</span><code>#F5E8D0</code>
          </div>
          <div class="swatch" style="background:#B4AA9A;color:#0E0D0D;">
            <span>Body</span><code>#B4AA9A</code>
          </div>
          <div class="swatch" style="background:#BB3F2F;">
            <span>Accent</span><code>#BB3F2F</code>
          </div>
          <div class="swatch" style="background:#E6B649;color:#0E0D0D;">
            <span>Gold</span><code>#E6B649</code>
          </div>
        </div>
      </section>

      <!-- Buttons -->
      <section class="specimen-block">
        <div class="specimen-label">BUTTONS · PRIMARY + SECONDARY</div>
        <div class="button-row">
          <a href="#" class="btn-primary">VIEW THE WORK →</a>
          <a href="#" class="btn-secondary">DOWNLOAD CV</a>
        </div>
      </section>

      <!-- Shadow variants -->
      <section class="specimen-block">
        <div class="specimen-label">SHADOW SYSTEM · HARD OFFSET ONLY (NO BLUR)</div>
        <div class="shadow-row">
          <div class="shadow-demo shadow-comic-ink">COMIC<br/>(INK)</div>
          <div class="shadow-demo shadow-comic-red-demo">COMIC-RED<br/>(ACCENT)</div>
          <div class="shadow-demo shadow-comic-card-demo">COMIC-CARD<br/>(+1PX)</div>
        </div>
      </section>

      <!-- Design rule summary -->
      <section class="specimen-block philosophy-callout">
        <div class="callout-label">DESIGN PHILOSOPHY</div>
        <p class="callout-quote">
          "A space should teach the player without a single line of instruction."
        </p>
      </section>

      <!-- Stack confirmation -->
      <section class="specimen-block stack-info">
        <div class="specimen-label">STACK · CONFIRMED WORKING</div>
        <div class="stack-chips">
          <span class="chip">Astro 6</span>
          <span class="chip">Tailwind 3</span>
          <span class="chip">MDX</span>
          <span class="chip">PostCSS</span>
          <span class="chip">GitHub Pages</span>
          <span class="chip">Anton ✓</span>
          <span class="chip">Pirata One ✓</span>
          <span class="chip">Oswald ✓</span>
          <span class="chip">Bangers ✓</span>
          <span class="chip">Comic Neue ✓</span>
          <span class="chip">Inter ✓</span>
        </div>
      </section>

    </div><!-- /container -->

    <footer class="scaffold-footer">
      <span class="label-oswald">STEFAN MALINOVIC</span>
      <span class="label-oswald muted">SENIOR LEVEL &amp; GAME DESIGNER</span>
      <span class="label-oswald muted">PHASE 1 COMPLETE · NEXT: LAYOUT + HEADER</span>
    </footer>

  </main>
</Layout>

<style>
  /* ── Layout ────────────────────────────────────────────────────── */
  .scaffold-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem 2rem;
    border-bottom: 2px solid #F5E8D0;
    position: sticky;
    top: 0;
    z-index: 100;
    background: #0E0D0D;
  }

  .logo-mark {
    font-family: 'Anton', Impact, sans-serif;
    font-size: 1.75rem;
    letter-spacing: -0.02em;
    color: #F5E8D0;
  }

  .logo-mark span {
    color: #BB3F2F;
  }

  nav {
    display: flex;
    gap: 2rem;
    font-family: 'Oswald', system-ui, sans-serif;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  nav a {
    color: #F5E8D0;
    transition: color 0.15s;
  }

  nav a:hover { color: #BB3F2F; }

  .nav-contact {
    color: #BB3F2F !important;
    border: 2px solid #BB3F2F;
    padding: 0.25rem 0.75rem;
  }

  .container {
    max-width: 960px;
    margin: 0 auto;
    padding: 3rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  /* ── Phase badge ───────────────────────────────────────────────── */
  .phase-badge {
    display: inline-flex;
    align-items: center;
    background: #BB3F2F;
    color: #F5E8D0;
    font-family: 'Oswald', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 0.4rem 1rem;
    box-shadow: 4px 4px 0 #F5E8D0;
  }

  /* ── Specimen blocks ───────────────────────────────────────────── */
  .specimen-block {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border-left: 3px dashed #BB3F2F;
    padding-left: 1.5rem;
  }

  .specimen-label {
    font-family: 'Oswald', sans-serif;
    font-weight: 400;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #5D5954;
  }

  /* ── Hero name ─────────────────────────────────────────────────── */
  .hero-name {
    font-family: 'Anton', Impact, sans-serif;
    font-size: clamp(3rem, 10vw, 7rem);
    letter-spacing: -0.03em;
    line-height: 0.88;
    color: #F5E8D0;
  }

  .accent-dot { color: #BB3F2F; }

  .hero-sub {
    font-family: 'Oswald', sans-serif;
    font-weight: 500;
    font-size: 0.9rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #B4AA9A;
  }

  /* ── Gothic title ──────────────────────────────────────────────── */
  .gothic-title {
    font-family: 'Pirata One', serif;
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    color: #F5E8D0;
    letter-spacing: 0.04em;
    font-weight: 400;
  }

  /* ── UI labels ─────────────────────────────────────────────────── */
  .ui-label {
    font-family: 'Oswald', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #F5E8D0;
  }

  /* ── Impact callouts ───────────────────────────────────────────── */
  .impact-text {
    font-family: 'Bangers', cursive;
    font-size: clamp(2rem, 6vw, 4rem);
    letter-spacing: 0.05em;
    color: #BB3F2F;
    line-height: 1;
  }

  /* ── Speech bubble demo ────────────────────────────────────────── */
  .speech-bubble-demo {
    position: relative;
    display: inline-block;
    background: #F5E8D0;
    border: 3px solid #0E0D0D;
    border-radius: 12px;
    padding: 1rem 1.5rem;
    max-width: 400px;
    box-shadow: 4px 4px 0 #0E0D0D;
  }

  .bubble-text {
    font-family: 'Comic Neue', cursive;
    font-weight: 700;
    font-style: italic;
    font-size: 1.1rem;
    color: #0E0D0D;
    margin: 0;
  }

  .bubble-tail {
    position: absolute;
    bottom: -16px;
    left: 24px;
    width: 0;
    height: 0;
    border-left: 10px solid transparent;
    border-right: 10px solid transparent;
    border-top: 16px solid #0E0D0D;
  }

  .bubble-tail::after {
    content: '';
    position: absolute;
    top: -19px;
    left: -8px;
    width: 0;
    height: 0;
    border-left: 8px solid transparent;
    border-right: 8px solid transparent;
    border-top: 14px solid #F5E8D0;
  }

  /* ── Body text ─────────────────────────────────────────────────── */
  .body-text {
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.7;
    color: #B4AA9A;
    max-width: 620px;
  }

  /* ── Color swatches ────────────────────────────────────────────── */
  .swatch-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .swatch {
    width: 120px;
    padding: 0.75rem;
    border: 1px solid rgba(245,232,208,0.2);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .swatch span {
    font-family: 'Oswald', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .swatch code {
    font-family: 'Courier New', monospace;
    font-size: 0.65rem;
    color: inherit;
    opacity: 0.7;
  }

  /* ── Buttons ───────────────────────────────────────────────────── */
  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
  }

  .btn-primary {
    display: inline-block;
    background: #BB3F2F;
    color: #F5E8D0;
    font-family: 'Oswald', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 0.75rem 1.75rem;
    border: 2px solid #BB3F2F;
    box-shadow: 4px 4px 0 #F5E8D0;
    transition: box-shadow 0.1s, transform 0.1s;
    cursor: pointer;
  }

  .btn-primary:hover {
    box-shadow: 2px 2px 0 #F5E8D0;
    transform: translate(2px, 2px);
  }

  .btn-secondary {
    display: inline-block;
    background: transparent;
    color: #F5E8D0;
    font-family: 'Oswald', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 0.75rem 1.75rem;
    border: 2px solid #F5E8D0;
    box-shadow: 4px 4px 0 #BB3F2F;
    transition: box-shadow 0.1s, transform 0.1s;
    cursor: pointer;
  }

  .btn-secondary:hover {
    box-shadow: 2px 2px 0 #BB3F2F;
    transform: translate(2px, 2px);
  }

  /* ── Shadow demos ──────────────────────────────────────────────── */
  .shadow-row {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    align-items: flex-start;
  }

  .shadow-demo {
    background: #1B1918;
    color: #F5E8D0;
    font-family: 'Oswald', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 1rem 1.5rem;
    border: 2px solid #F5E8D0;
    text-align: center;
    line-height: 1.4;
  }

  .shadow-comic-ink       { box-shadow: 4px 4px 0 #0E0D0D; border-color: #F5E8D0; }
  .shadow-comic-red-demo  { box-shadow: 4px 4px 0 #BB3F2F; }
  .shadow-comic-card-demo { box-shadow: 5px 5px 0 #BB3F2F; }

  /* ── Philosophy callout ────────────────────────────────────────── */
  .philosophy-callout {
    position: relative;
    border: 2px dashed #BB3F2F;
    padding: 2rem 1.5rem 1.5rem;
    margin-top: 1rem;
    border-left: none;
  }

  .callout-label {
    position: absolute;
    top: -0.65rem;
    left: 1.5rem;
    background: #0E0D0D;
    padding: 0 0.5rem;
    font-family: 'Oswald', sans-serif;
    font-weight: 700;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #BB3F2F;
  }

  .callout-quote {
    font-family: 'Inter', sans-serif;
    font-style: italic;
    font-size: 1.1rem;
    line-height: 1.6;
    color: #F5E8D0;
    margin: 0;
  }

  /* ── Stack chips ───────────────────────────────────────────────── */
  .stack-info { border-color: #E6B649; }

  .stack-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .chip {
    background: #1B1918;
    color: #F5E8D0;
    font-family: 'Oswald', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.3rem 0.75rem;
    border: 1px solid #5D5954;
  }

  /* ── Footer ────────────────────────────────────────────────────── */
  .scaffold-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 1.25rem 2rem;
    border-top: 1px solid #1B1918;
    margin-top: 4rem;
  }

  .label-oswald {
    font-family: 'Oswald', sans-serif;
    font-weight: 700;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #F5E8D0;
  }

  .label-oswald.muted { color: #5D5954; }

  /* ── Responsive ────────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .scaffold-header { flex-direction: column; gap: 1rem; text-align: center; }
    nav { gap: 1rem; }
    .scaffold-footer { justify-content: center; text-align: center; }
    .swatch-row { gap: 0.5rem; }
    .swatch { width: calc(50% - 0.25rem); }
  }
</style>
