---
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  const slugs = [
    'tales-edge',
    'riders-republic',
    'ac-nexus-vr',
    'milc',
    'tetris',
    'steep',
    'game-jams',
    'mobile-apps',
  ];
  return slugs.map(slug => ({ params: { slug } }));
}

// ── Project data ────────────────────────────────────────────────────────────
const projects: Record<string, {
  title: string;
  tag: string;
  studio: string;
  role: string;
  engine: string;
  year: string;
  platform: string;
  cover: string;
  images: string[];
  owned: string;
  brief: string;
  problem: string;
  approach: string;
  result: string;
  reflection: string;
  discipline: string[];
}> = {
  'tales-edge': {
    title: 'Tales Edge',
    tag: 'CURRENT',
    studio: 'RedSixteen Interactive',
    role: 'Sr. / Lead Level Designer',
    engine: 'Unreal Engine 5.7',
    year: '2024–Present',
    platform: 'PC',
    cover: '/assets/projects/tales-edge/tales-edge-02.webp',
    images: [
      '/assets/projects/tales-edge/tales-edge-01.webp',
      '/assets/projects/tales-edge/tales-edge-03.webp',
      '/assets/projects/tales-edge/tales-edge-04.webp',
      '/assets/projects/tales-edge/tales-edge-05.webp',
      '/assets/projects/tales-edge/tales-edge-06.webp',
    ],
    owned: "Built the level-design pipeline from the ground up — blockout standards, validation gyms and metric reference systems — and led level design for the game's combat, stealth and parkour spaces. 100+ gym maps, 4 public playable builds, and the trailer level.",
    brief: "Tales Edge needed a level-design discipline from zero: standards, tools and a pipeline that let any space be tested and tuned in isolation, plus playable levels that prove a stealth/parkour/detective-quest loop reads clearly.",
    problem: "A different approach to stealth, parkour and detective-style quest flow — deep emphasis on spatial readability and player guidance — built on a movement system and AI that were both being overhauled mid-development.",
    approach: "I co-shape the core loop with the Game Design Director by designing the spaces it plays out in, then tune traversal and AI encounters through constant iteration across public playtests. Key locations include Hoofensmith Island (port edge of the Enchanted Forest — tested worldscale, tree-parkour, quests, stealth, and told the island's whole history through worldbuilding), Whisperwood Outpost (rough 2D map → concept art → detailed 2D map → 3D greybox, testing the UE world-creation pipeline with latest terrain plugins), and the Small Bridge Encounter gym (first test of the AI stealth overhaul: vision, sound, hearing, Rest/Feed 'Need Spots').",
    result: 'A working LD pipeline, four public builds, a trailer level, and a stealth ruleset that scales to new maps.',
    reflection: 'Designing alongside systems that are still changing forces you to build for change — modular gyms and clear standards are what keep a moving target shippable.',
    discipline: ['Level Design', 'Game Design', '3D/Environment'],
  },
  'riders-republic': {
    title: 'Riders Republic',
    tag: 'AAA',
    studio: 'Ubisoft',
    role: 'Level Designer',
    engine: 'Anvil',
    year: '2019–2021',
    platform: 'PC / Console',
    cover: '/assets/projects/riders-republic/riders-republic-10.webp',
    images: [
      '/assets/projects/riders-republic/riders-republic-01.webp',
      '/assets/projects/riders-republic/riders-republic-03.webp',
      '/assets/projects/riders-republic/riders-republic-05.webp',
      '/assets/projects/riders-republic/riders-republic-07.webp',
      '/assets/projects/riders-republic/riders-republic-12.webp',
    ],
    owned: 'All 45 in-world Landmarks (scouting, layout, technical scripting, wildlife and cinematic setup) and 11 named stunt challenges (route blockout, checkpoint placement, spatial pacing and difficulty tuning) — plus a contribution to the Showdown PvP arena layout.',
    brief: 'Fill an open world with gameplay-relevant landmarks and readable, replayable stunt routes across a satisfying skill curve.',
    problem: 'Make each landmark a designed experience, and tune stunt difficulty through checkpoint geometry and pacing rather than blunt obstacles.',
    approach: "Landmarks as authored moments: The Subway starts in darkness and ends in light, with integrated bats and birdsong at the canyon mouth for a full journey. Double Arch had its camera animated and final framing tilted for a stronger composition. Cascade Canyon communicated full wilderness through bears, birds, fish and eagles. Delicate Arch was switched from day to night — a flock leaving the arch against a desolate desert shows life blooming where no one lives. Stunts: Cloud Flight (wingsuit speedrun — I negotiated ±25% checkpoint sizes so skimming the dangerous edge buys a time advantage over center) became a real speedrun community target.",
    result: 'Shipped open-world content played, streamed and speedrun by players. Cloud Flight generated YouTube speedrun communities.',
    reflection: 'Small affordances — a checkpoint 25% bigger, a camera tilt — change how a whole space is read and replayed. Tuning the edges is the work.',
    discipline: ['Level Design', '3D/Environment'],
  },
  'ac-nexus-vr': {
    title: "Assassin's Creed Nexus VR",
    tag: 'VR',
    studio: 'Ubisoft',
    role: 'Level & Mission Designer',
    engine: 'Unity',
    year: '2021–2022',
    platform: 'Meta Quest',
    cover: '/assets/projects/ac-nexus-vr/ac-nexus-vr-01.webp',
    images: [
      '/assets/projects/ac-nexus-vr/ac-nexus-vr-02.webp',
      '/assets/projects/ac-nexus-vr/ac-nexus-vr-03.webp',
      '/assets/projects/ac-nexus-vr/ac-nexus-vr-04.webp',
      '/assets/projects/ac-nexus-vr/ac-nexus-vr-05.webp',
      '/assets/projects/ac-nexus-vr/ac-nexus-vr-06.webp',
    ],
    owned: 'Mission levels and encounter spaces across 4 missions (2 end-to-end) — Return to Monteriggioni, Monteriggioni Tunnels, To Save the City, Return of the Cult of Hermes — covering parkour traversal layout, sightlines, mission flow, AI placement and set-piece scripting, designed natively for VR.',
    brief: 'Design AC mission levels for VR, where the player has hands and a head, not a controller — scale, sightlines and readability all behave differently.',
    problem: 'Build dense, legible spaces that support multiple routes (stealth as the intended path, combat as a fallback) and hold up to a player who can physically lean, reach and look anywhere.',
    approach: 'Venice Clocktower puzzle & market pickup: a small dense puzzle space with all pieces reachable, lead-in through an open market patrolled by a mini-boss holding a needed key — I designed and pitched the "three-finger" dock shape that devtesters confirmed was ideal for stealth (enough cover and decoy options, plus a traversal challenge in a small footprint). Return to Monteriggioni → Tunnels → To Save the City: three missions in one, a full ~1.5h experience — I designed the entire mission flow, scripts, boss fight, objectives, side objectives, easter eggs, and scripted the NPCs.',
    result: 'Shipped VR missions including a 1.5-hour set-piece sequence across three connected missions.',
    reflection: "VR punishes anything you can't read at a glance — designing for a body, not a camera, sharpened how I think about sightlines everywhere since.",
    discipline: ['Level Design', 'Game Design'],
  },
  'milc': {
    title: 'MILC Metaverse',
    tag: 'INDIE',
    studio: 'Welt der Wunder / MILC',
    role: 'Lead Designer (Game & Level)',
    engine: 'Unreal Engine 4 & 5',
    year: '2022–2025',
    platform: 'Web (real-time)',
    cover: '/assets/projects/milc/milc-04.webp',
    images: [
      '/assets/projects/milc/milc-01.webp',
      '/assets/projects/milc/milc-02.webp',
      '/assets/projects/milc/milc-03.webp',
    ],
    owned: 'Led a 9-person team and owned feature design, world systems, the Product Design Document and the Art Bible for a commercial real-time platform; designed and created ~52 levels and directed the content inside each.',
    brief: 'Turn commercial briefs from brands — Marc Cain, Karl Lagerfeld, Lufthansa, Red Bull, Swarovski, Cannes & Oldenburg Film Festivals — into spatial, systemic experiences that guide users toward measurable engagement goals.',
    problem: 'Designing for retention and conversion: embed business logic into spaces that still feel like places worth being in.',
    approach: "Re-designed and rebuilt the main \"business island\" over 3 months — designing and modelling everything personally when the project had no other 3D artist. For the Oldenburg Film Festival, designed and co-created the city's most iconic buildings (evoking the city's feel, not a 1:1 copy) and recreated the Oldenburg Opera Haus interiors for their film projections — a 2-month team challenge. Also designed and built the MILC Art Gallery, Music Palace, Zapzee partner house (South Korea) and investor meeting room.",
    result: 'A live commercial platform delivering brand experiences for major clients; ~52 shipped levels, 9-person team led end-to-end.',
    reflection: "Designing for conversion is the same muscle as designing for a core loop — you're still guiding a player toward a goal they choose to pursue.",
    discipline: ['Game Design', '3D/Environment', 'Level Design'],
  },
  'tetris': {
    title: 'Tetris — Free-to-Play Mobile',
    tag: 'F2P',
    studio: 'PlayStudios',
    role: 'Technical Artist',
    engine: 'Unity + proprietary',
    year: '2022–2023',
    platform: 'Mobile',
    cover: '/assets/projects/tetris/tetris-01.webp',
    images: [],
    owned: 'Built the visual asset pipeline and implemented gameplay logic (C#, Lua, XML) on a live F2P title under Tetris Co. licensing — bridging design, art, programming and UX.',
    brief: 'Deliver live-game quality content for a licensed F2P Tetris title under Tetris Co. standards, bridging the art and engineering pipeline.',
    problem: 'Making a technically demanding pipeline work across art, code and UX — under strict licensing constraints and fast-paced live-game delivery schedules.',
    approach: 'Built the visual asset pipeline from the ground up and took on gameplay logic implementation in C#, Lua and XML — the full technical-artist scope, crossing into game design and engineering where needed.',
    result: 'Direct free-to-play mobile production experience: first-hand understanding of F2P systems, progression and live content under a major licence.',
    reflection: 'F2P teaches you to design for retention every minute, not just for the first hour.',
    discipline: ['3D/Environment', 'Game Design'],
  },
  'steep': {
    title: 'Steep & Steep: Open Japan',
    tag: 'AAA',
    studio: 'Ubisoft',
    role: 'Development Tester',
    engine: 'Anvil',
    year: '2018–2020',
    platform: 'PC / Console / VR / Switch',
    cover: '/assets/projects/riders-republic/riders-republic-02.webp',
    images: ['/assets/projects/riders-republic/riders-republic-04.webp'],
    owned: 'Tested open-world systems, multiplayer arenas and a prototype 4-team multiplayer mode on a 400+ person AAA production — balance testing, risk assessment and technical documentation across PC, Xbox, PlayStation, VR and Switch.',
    brief: "Ensure quality, balance and stability across Steep's open-world systems and multiplayer modes as the game shipped to multiple platforms.",
    problem: 'Testing at this scale means reading level design and balance decisions — understanding WHY something is broken, not just that it is.',
    approach: "Embedded in the level design and systems teams: balance testing, risk assessment and documentation that crossed from QA into genuine LD and systems analysis. First exposure to Anvil Engine, Ubisoft's pipeline, and professional LD standards.",
    result: 'Shipped across PC, Xbox, PlayStation, VR and Switch. First step into the Ubisoft pipeline that led directly to level design on Riders Republic.',
    reflection: 'Testing a game you want to design is the best education in level design you can get — you see every mistake at 1:1 scale.',
    discipline: ['Level Design'],
  },
  'game-jams': {
    title: 'Personal & Game Jam Projects',
    tag: 'JAM',
    studio: 'Independent',
    role: 'Designer & Developer',
    engine: 'Various (UE5, Unity, Hammer)',
    year: '2018–Present',
    platform: 'PC',
    cover: '/assets/projects/jams/jams-01.webp',
    images: [],
    owned: 'Solo and jam projects testing ideas outside the studio pipeline — where experiments are fast, stakes are low and learning is immediate.',
    brief: 'Build complete game experiences solo in constrained time, testing design muscles that AAA pipelines don\'t always let you flex.',
    problem: 'Constrained resources (time, people, tools) force prioritisation — every decision is a design decision.',
    approach: "The Great Esc (2nd place, Unreal Game Jam 2024) — puzzle/escape game with level design in 48 hours. Duality / It's Just You (Global Game Jam 2022) — game design, worldbuilding, level design and 3D art in UE5. Counter-Strike map (Hammer) — competitive multiplayer map with narrative framing and bomb-site balance. Hitman mission (paper design) — pure systemic mission design: multiple infiltration routes, opportunities and a fully briefed target, no engine required.",
    result: '2nd place at Unreal Game Jam 2024. Multiple shipped jam games.',
    reflection: 'Game jams compress the full design loop into 48 hours — you learn what\'s essential fast.',
    discipline: ['Level Design', 'Game Design'],
  },
  'mobile-apps': {
    title: 'Independent Products',
    tag: 'INDIE',
    studio: 'Triardor DOO',
    role: 'Product Designer',
    engine: 'React Native / Next.js / Unreal',
    year: '2020–Present',
    platform: 'Mobile / Web',
    cover: '/assets/projects/apps/apps-01.webp',
    images: [],
    owned: 'Self-directed apps and platforms shipped with AI-augmented workflows — the same systems-design, gamification and freemium muscles used in live-game design.',
    brief: 'Apply game design principles — core loop, retention, freemium, onboarding — to real-world software products.',
    problem: 'Designing products people actually use requires the same thinking as designing levels people actually explore: readability, reward loops and knowing when to get out of the way.',
    approach: 'Qponko — privacy-first loyalty wallet with gamified UX and freemium model across 38 languages. Waylo — intercity carpooling as a Telegram Mini App with freemium economics. Lex Ardor — Serbian-language AI legal assistant on a custom legal dataset. Spektrum Control — fire-safety inspection automation and document digitalization.',
    result: 'Multiple live products across mobile, web and Telegram — all built solo or in a very small team.',
    reflection: 'Shipping products outside games keeps the systems-design muscle sharp and honest.',
    discipline: ['Game Design'],
  },
};

// ── Slug resolution ─────────────────────────────────────────────────────────
const { slug } = Astro.params;
const project = projects[slug as string];

if (!project) {
  return Astro.redirect('/work');
}

// ── Next/prev navigation ────────────────────────────────────────────────────
const allSlugs = Object.keys(projects);
const currentIndex = allSlugs.indexOf(slug as string);
const prevSlug = currentIndex > 0 ? allSlugs[currentIndex - 1] : null;
const nextSlug = currentIndex < allSlugs.length - 1 ? allSlugs[currentIndex + 1] : null;
const prevProject = prevSlug ? projects[prevSlug] : null;
const nextProject = nextSlug ? projects[nextSlug] : null;

// ── Tag color mapping ───────────────────────────────────────────────────────
const tagColors: Record<string, string> = {
  CURRENT: '#E6B649',
  AAA:     '#BB3F2F',
  VR:      '#4A90D9',
  INDIE:   '#6BAA75',
  F2P:     '#C07BC0',
  JAM:     '#E6B649',
};
const tagColor = tagColors[project.tag] ?? 'var(--body)';
---

<Layout
  title={`${project.title} — Case Study · Stefan Malinovic`}
  description={`${project.role} at ${project.studio}. ${project.owned.slice(0, 140)}…`}
>

<!-- ═══════════════════════════════════════════════════════════════════════ -->
<!-- HERO STRIP                                                              -->
<!-- ═══════════════════════════════════════════════════════════════════════ -->
<section class="cs-hero" aria-label="Project hero">
  <div class="cs-hero__image-wrap">
    <img
      src={project.cover}
      alt={`${project.title} — cover`}
      class="cs-hero__image"
      loading="eager"
      decoding="async"
    />
    <div class="cs-hero__overlay" aria-hidden="true"></div>
  </div>

  <div class="cs-hero__content section-inner">
    <!-- Tag badge -->
    <span
      class="cs-tag font-ui"
      style={`--tag-color: ${tagColor}; --reveal-delay: 0ms;`}
      data-reveal
    >
      {project.tag}
    </span>

    <!-- Title -->
    <h1 class="cs-hero__title font-display" data-reveal style="--reveal-delay:80ms">
      {project.title}
    </h1>

    <!-- Meta row -->
    <p class="cs-hero__meta font-ui" data-reveal style="--reveal-delay:160ms">
      <span>{project.studio}</span>
      <span class="cs-meta-sep" aria-hidden="true">·</span>
      <span>{project.role}</span>
      <span class="cs-meta-sep" aria-hidden="true">·</span>
      <span>{project.engine}</span>
      <span class="cs-meta-sep" aria-hidden="true">·</span>
      <span>{project.year}</span>
      <span class="cs-meta-sep" aria-hidden="true">·</span>
      <span>{project.platform}</span>
    </p>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════════════ -->
<!-- METADATA BAND                                                           -->
<!-- ═══════════════════════════════════════════════════════════════════════ -->
<section class="cs-meta-band" aria-label="Project metadata">
  <div class="section-inner cs-meta-band__inner">

    <!-- Breadcrumb -->
    <div class="cs-meta-band__breadcrumb" data-reveal style="--reveal-delay:0ms">
      <a href="/work" class="cs-back-link font-ui" aria-label="Back to Work index">
        <span class="cs-back-arrow" aria-hidden="true">←</span>
        BACK TO WORK
      </a>
    </div>

    <!-- Meta columns -->
    <div class="cs-meta-band__cols">
      <div class="cs-meta-col" data-reveal style="--reveal-delay:60ms">
        <span class="cs-meta-label font-ui">Studio</span>
        <span class="cs-meta-value font-body">{project.studio}</span>
      </div>
      <div class="cs-meta-col" data-reveal style="--reveal-delay:100ms">
        <span class="cs-meta-label font-ui">Role</span>
        <span class="cs-meta-value font-body">{project.role}</span>
      </div>
      <div class="cs-meta-col" data-reveal style="--reveal-delay:140ms">
        <span class="cs-meta-label font-ui">Engine</span>
        <span class="cs-meta-value font-body">{project.engine}</span>
      </div>
      <div class="cs-meta-col" data-reveal style="--reveal-delay:180ms">
        <span class="cs-meta-label font-ui">Platform</span>
        <span class="cs-meta-value font-body">{project.platform}</span>
      </div>
      <div class="cs-meta-col cs-meta-col--disciplines" data-reveal style="--reveal-delay:220ms">
        <span class="cs-meta-label font-ui">Disciplines</span>
        <div class="cs-chips">
          {project.discipline.map(d => (
            <span class="cs-chip font-ui">{d}</span>
          ))}
        </div>
      </div>
    </div>

  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════════════ -->
<!-- WHAT I OWNED                                                            -->
<!-- ═══════════════════════════════════════════════════════════════════════ -->
<section class="cs-owned" aria-label="What I owned on this project">
  <div class="section-inner">
    <div class="philosophy-callout cs-owned__callout" data-reveal style="--reveal-delay:0ms">
      <span class="callout-label">WHAT I OWNED</span>
      <p class="cs-owned__text font-body">{project.owned}</p>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════════════ -->
<!-- CASE STUDY BODY                                                         -->
<!-- ═══════════════════════════════════════════════════════════════════════ -->
<section class="cs-body" aria-label="Case study">
  <div class="section-inner cs-body__inner">

    <!-- THE BRIEF -->
    <div class="cs-section-block" data-reveal style="--reveal-delay:0ms">
      <h2 class="cs-section-label font-ui">The Brief</h2>
      <div class="cs-section-rule" aria-hidden="true"></div>
      <p class="cs-section-text font-body">{project.brief}</p>
    </div>

    <!-- THE DESIGN PROBLEM -->
    <div class="cs-section-block" data-reveal style="--reveal-delay:80ms">
      <h2 class="cs-section-label font-ui">The Design Problem</h2>
      <div class="cs-section-rule" aria-hidden="true"></div>
      <p class="cs-section-text font-body">{project.problem}</p>
    </div>

    <!-- MY APPROACH -->
    <div class="cs-section-block" data-reveal style="--reveal-delay:160ms">
      <h2 class="cs-section-label font-ui">My Approach</h2>
      <div class="cs-section-rule" aria-hidden="true"></div>
      <p class="cs-section-text font-body">{project.approach}</p>
    </div>

  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════════════ -->
<!-- RESULT & REFLECTION                                                     -->
<!-- ═══════════════════════════════════════════════════════════════════════ -->
<section class="cs-outcome" aria-label="Result and reflection">
  <div class="section-inner cs-outcome__inner">

    <!-- Result -->
    <div class="cs-result" data-reveal style="--reveal-delay:0ms">
      <h2 class="cs-section-label font-ui">Result</h2>
      <div class="cs-section-rule" aria-hidden="true"></div>
      <p class="cs-result__text font-body">{project.result}</p>
    </div>

    <!-- Reflection -->
    <div class="cs-reflection" data-reveal style="--reveal-delay:120ms">
      <h2 class="cs-section-label font-ui">Reflection</h2>
      <div class="cs-section-rule cs-section-rule--gold" aria-hidden="true"></div>
      <blockquote class="cs-reflection__quote font-body">
        <span class="cs-reflection__mark" aria-hidden="true">"</span>
        {project.reflection}
      </blockquote>
    </div>

  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════════════ -->
<!-- IMAGE GALLERY (only if images exist)                                    -->
<!-- ═══════════════════════════════════════════════════════════════════════ -->
{project.images.length > 0 && (
  <section class="cs-gallery" aria-label="Project images">
    <div class="section-inner">
      <h2 class="cs-gallery__heading section-title" data-reveal style="--reveal-delay:0ms">
        From the Project
      </h2>
      <div class="cs-gallery__grid">
        {project.images.map((src, i) => (
          <div
            class="cs-gallery__item"
            data-reveal
            style={`--reveal-delay:${i * 80}ms`}
          >
            <img
              src={src}
              alt={`${project.title} — screenshot ${i + 1}`}
              loading="lazy"
              decoding="async"
              class="cs-gallery__img"
            />
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<!-- ═══════════════════════════════════════════════════════════════════════ -->
<!-- NEXT / PREV NAVIGATION                                                  -->
<!-- ═══════════════════════════════════════════════════════════════════════ -->
<section class="cs-nav-strip" aria-label="Project navigation">
  <div class="section-inner cs-nav-strip__inner">

    {prevProject && prevSlug ? (
      <a href={`/work/${prevSlug}`} class="cs-nav-card cs-nav-card--prev" data-reveal style="--reveal-delay:0ms">
        <span class="cs-nav-card__dir font-ui">← Previous</span>
        <span class="cs-nav-card__title font-display">{prevProject.title}</span>
        <span class="cs-nav-card__tag font-ui">{prevProject.tag}</span>
      </a>
    ) : (
      <div class="cs-nav-card__placeholder"></div>
    )}

    <a href="/work" class="cs-nav-back btn-secondary" data-reveal style="--reveal-delay:80ms">
      ← ALL WORK
    </a>

    {nextProject && nextSlug ? (
      <a href={`/work/${nextSlug}`} class="cs-nav-card cs-nav-card--next" data-reveal style="--reveal-delay:0ms">
        <span class="cs-nav-card__dir font-ui">Next →</span>
        <span class="cs-nav-card__title font-display">{nextProject.title}</span>
        <span class="cs-nav-card__tag font-ui">{nextProject.tag}</span>
      </a>
    ) : (
      <div class="cs-nav-card__placeholder"></div>
    )}

  </div>
</section>

</Layout>

<!-- ═══════════════════════════════════════════════════════════════════════ -->
<!-- PAGE-SPECIFIC STYLES                                                    -->
<!-- ═══════════════════════════════════════════════════════════════════════ -->
<style>
/* ── Reveal ─────────────────────────────────────────────────────────────── */
[data-reveal] {
  opacity: 0;
  transform: translateY(22px);
  transition:
    opacity  0.55s ease var(--reveal-delay, 0ms),
    transform 0.55s ease var(--reveal-delay, 0ms);
}
[data-reveal].is-visible {
  opacity: 1;
  transform: translateY(0);
}
@media (prefers-reduced-motion: reduce) {
  [data-reveal] { opacity: 1; transform: none; transition: none; }
}

/* ── Hero ───────────────────────────────────────────────────────────────── */
.cs-hero {
  position: relative;
  height: clamp(320px, 45vw, 520px);
  overflow: hidden;
  display: flex;
  align-items: flex-end;
}

.cs-hero__image-wrap {
  position: absolute;
  inset: 0;
}

.cs-hero__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 30%;
  display: block;
}

.cs-hero__overlay {
  position: absolute;
  inset: 0;
  /* Cinematic gradient: dark at bottom for text legibility, subtle at top */
  background: linear-gradient(
    to bottom,
    rgba(14, 13, 13, 0.25) 0%,
    rgba(14, 13, 13, 0.15) 40%,
    rgba(14, 13, 13, 0.75) 75%,
    rgba(14, 13, 13, 0.95) 100%
  );
}

.cs-hero__content {
