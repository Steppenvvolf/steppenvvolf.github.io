  .studio-sep { display: none; }
}

@media (max-width: 480px) {
  .timeline-item {
    grid-template-columns: 1fr;
  }
  .tl-node { display: none; }
  .tl-year {
    text-align: left;
    font-size: 1rem;
    margin-bottom: 0.25rem;
  }
  .cta-actions { flex-direction: column; }
}
</style>
