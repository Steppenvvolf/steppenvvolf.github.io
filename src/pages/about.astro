  color: #BB3F2F;
}

.intro-title {
  font-size: clamp(2.2rem, 5.5vw, 4.5rem);
  font-weight: 400;
  color: #F5E8D0;
  letter-spacing: 0.03em;
  line-height: 0.95;
  margin-bottom: 1.75rem;
}
.accent-dot { color: #BB3F2F; }

.intro-para {
  font-size: 0.93rem;
  color: #B4AA9A;
  line-height: 1.75;
  margin-bottom: 1rem;
  max-width: 55ch;
}

.intro-ctas {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  margin-top: 2rem;
}

/* ── Stat card ───────────────────────────────────────────────────────────── */
.intro-stat-card {
  border: 2px solid #F5E8D0;
  box-shadow: 6px 6px 0 #BB3F2F;
  background: #1B1918;
  padding: 2rem 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0;
  position: relative;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 1.25rem 0;
  text-align: center;
}

.stat-num {
  font-size: clamp(2.8rem, 5vw, 4rem);
  color: #E6B649;
  line-height: 1;
  letter-spacing: -0.04em;
}

.stat-label {
  font-size: 0.62rem;
  color: #5D5954;
  letter-spacing: 0.2em;
  margin-top: 0.35rem;
}

.stat-divider {
  height: 1px;
  background: #1B1918;
  border-top: 1px solid #3D3935;
  margin: 0;
}

.stat-badge {
  margin-top: 1.5rem;
  background: #BB3F2F;
  padding: 0.45rem 0.75rem;
  text-align: center;
}

.stat-badge span {
  font-size: 0.6rem;
  color: #F5E8D0;
  letter-spacing: 0.15em;
}

/* ── Timeline ────────────────────────────────────────────────────────────── */
.timeline-section { padding: 5rem 0; }

.timeline {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
}

.timeline-item {
  display: grid;
  grid-template-columns: 5.5rem 2rem 1fr;
