.tl-title {
  font-size: 0.88rem;
  color: #F5E8D0;
  margin-bottom: 0.3rem;
}

.tl-place {
  font-size: 0.68rem;
  color: #BB3F2F;
  letter-spacing: 0.15em;
  margin-bottom: 0.65rem;
}

.tl-desc {
  font-size: 0.85rem;
  color: #B4AA9A;
  line-height: 1.7;
}

/* ── Education ───────────────────────────────────────────────────────────── */
.edu-section {
  padding: 5rem 0;
  border-top: 1px solid #1B1918;
}

.edu-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5rem;
