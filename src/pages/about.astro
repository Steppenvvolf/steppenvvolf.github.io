---
import Layout from '../layouts/Layout.astro';

const timeline = [
  {
    year: "2024–NOW",
    title: "Sr. / Lead Level Designer",
    place: "RedSixteen Interactive — Tales Edge (UE5)",
    desc: "Built the LD & world-creation pipeline from scratch; 100+ gym maps, 4 public builds, trailer level. Belgrade / San Diego / Montreal.",
  },
  {
    year: "2022–2025",
    title: "Lead Designer (Game & Level)",
    place: "Welt der Wunder / MILC — MILC Metaverse (UE4→5)",
    desc: "Led a 9-person team; owned the Product Design Document and Art Bible; ~52 levels. Belgrade / Munich.",
  },
  {
    year: "2022–2023",
    title: "Technical Artist",
    place: "PlayStudios — Tetris F2P Mobile",
    desc: "Built the visual asset pipeline; gameplay logic in C#/Lua/XML. Belgrade / Tel Aviv / Las Vegas.",
  },
  {
    year: "2020–2022",
    title: "Level Designer",
    place: "Ubisoft — Riders Republic, AC Nexus VR",
    desc: "Designed levels and missions on Assassin's Creed Nexus VR and Riders Republic using Anvil and Unity. Belgrade / Annecy / Montpellier / Düsseldorf.",
  },
  {
    year: "2018–2020",
    title: "Development Tester & Level Designer",
    place: "Ubisoft — Steep, Steep DLC: Open Japan, Riders Republic",
    desc: "Development testing and level design work on Steep, its Open Japan DLC, and early Riders Republic on Anvil. Belgrade / Annecy.",
  },
];

const beyond = [
  {
    icon: "🏍",
    title: "Motorcycles & Road Trips",
    desc: "The biker aesthetic isn't decoration. It's how I think about freedom, movement and purpose.",
  },
  {
    icon: "🎸",
    title: "Rock & Electronic Music",
    desc: "Music Production and live shows. Sound and rhythm feed directly into how I design space and pacing.",
  },
  {
    icon: "📖",
    title: "WW2 History & Systems",
    desc: "I read history the way I read game designs — looking for the decisions behind the decisions.",
  },
];

const studios = ["UBISOFT", "REDSIXTEEN INTERACTIVE", "PLAYSTUDIOS", "MILC / WELT DER WUNDER"];

const education = [
  {
    degree: "Bachelor of Laws (Hons), LL.B.",
    institution: "University of Megatrend (John Naisbitt)",
    years: "2012–2016",
  },
  {
    degree: "Socio-Linguistic Diploma",
    institution: "Gymnasium Uroš Predić",
    years: "2008–2011",
    note: "English, German, Russian, Latin",
  },
];
---

<Layout
  title="About Stefan Malinovic — Senior Level & Game Designer"
  description="Eight years across AAA, VR, and free-to-play. Senior / Lead Level & Game Designer at RedSixteen Interactive. Based in Serbia."
>

<!-- ═══════════════════ INTRO ════════════════════════════════════════════ -->
<section class="intro-section" data-section>
  <div class="section-inner intro-inner">

    <div class="intro-text">
      <div class="intro-eyebrow">
        <span class="eyebrow-line"></span>
        <span class="eyebrow-label">THE DESIGNER</span>
      </div>
      <h1 class="intro-title font-gothic">About Stefan<span class="accent-dot">.</span></h1>

      <p class="intro-para font-body">
        I'm a Senior Level Designer with eight years across AAA, AA, VR and free-to-play titles. I own the full level-design pipeline — blockout, metrics, pacing, player flow, sightlines and environmental storytelling — and take spaces from greybox to ship.
      </p>
      <p class="intro-para font-body">
        Right now I'm Senior / Lead Level Designer on Tales Edge (Unreal Engine 5), where I built the level-design and world-creation pipeline from the ground up. Before that I designed levels and missions on Assassin's Creed Nexus VR and Riders Republic at Ubisoft, led game and level design on the MILC real-time platform, and shipped F2P mobile at PlayStudios.
      </p>
      <p class="intro-para font-body">
        I came to games sideways — through a law degree. That trained me to read systems, argue a design on its merits, and write documentation people actually use. I'm a generalist by curiosity and a specialist by craft: fluent across Unreal, Unity, Anvil and Hammer, and a fast study on any proprietary toolset you put in front of me.
      </p>

      <div class="intro-ctas">
        <a href="/work" class="btn-primary">VIEW THE WORK →</a>
        <a href="/process" class="btn-secondary">MY PROCESS</a>
      </div>
    </div>

    <div class="intro-card-wrap" data-card-reveal style="--card-delay:150ms">
      <div class="intro-stat-card">
        <div class="stat-item">
          <span class="stat-num font-display">8</span>
          <span class="stat-label font-ui">Years</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat-item">
          <span class="stat-num font-display">4</span>
          <span class="stat-label font-ui">Studios</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat-item">
          <span class="stat-num font-display">3</span>
          <span class="stat-label font-ui">Disciplines</span>
        </div>
        <div class="stat-badge">
          <span class="font-ui">CURRENTLY AT REDSIXTEEN</span>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- ═══════════════════ TIMELINE ════════════════════════════════════════ -->
<section class="timeline-section" data-section>
  <div class="section-inner">
    <div class="section-head">
      <h2 class="section-title">The Journey</h2>
      <span class="issue-label">2018 → PRESENT</span>
    </div>

    <ol class="timeline" role="list">
      {timeline.map((item, i) => (
        <li class="timeline-item" data-card-reveal style={`--card-delay:${i * 90}ms`}>
          <div class="tl-year font-display" aria-label={`Period ${item.year}`}>{item.year}</div>
          <div class="tl-node" aria-hidden="true">
            <div class="tl-dot"></div>
            <div class="tl-stem"></div>
          </div>
          <div class="tl-body">
            <h3 class="tl-title font-ui">{item.title}</h3>
            <p class="tl-place font-ui">{item.place}</p>
            <p class="tl-desc font-body">{item.desc}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<!-- ═══════════════════ EDUCATION & LANGUAGES ═══════════════════════════ -->
<section class="edu-section" data-section>
  <div class="section-inner">
    <div class="section-head">
      <h2 class="section-title">Education</h2>
      <span class="issue-label">BACKGROUND</span>
    </div>

    <div class="edu-grid">
      {education.map((item, i) => (
        <div class="edu-card" data-card-reveal style={`--card-delay:${i * 110}ms`}>
          <span class="edu-years font-display">{item.years}</span>
          <h3 class="edu-degree font-ui">{item.degree}</h3>
          <p class="edu-institution font-ui">{item.institution}</p>
          {item.note && <p class="edu-note font-body">{item.note}</p>}
        </div>
      ))}
    </div>

    <div class="lang-block" data-card-reveal style="--card-delay:220ms">
      <p class="lang-label font-ui">Languages</p>
      <p class="lang-list font-body">Serbian (native) · English (fluent) · Russian (basic) · German (basic)</p>
    </div>
  </div>
</section>

<!-- ═══════════════════ BEYOND WORK ═════════════════════════════════════ -->
<section class="beyond-section" data-section>
  <div class="section-inner">
    <div class="section-head">
      <h2 class="section-title">Beyond Work</h2>
      <span class="issue-label">THE HUMAN</span>
    </div>

    <div class="beyond-grid">
      {beyond.map((item, i) => (
        <div class="beyond-card" data-card-reveal style={`--card-delay:${i * 110}ms`}>
          <span class="beyond-icon" aria-hidden="true">{item.icon}</span>
          <h3 class="beyond-title font-ui">{item.title}</h3>
          <p class="beyond-desc font-body">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══════════════════ STUDIOS ══════════════════════════════════════════ -->
<section class="studios-section" data-section>
  <div class="section-inner">
    <p class="studios-eyebrow font-ui">Worked With</p>
    <div class="studios-row" role="list">
      {studios.map((s, i) => (
        <>
          <span class="studio-name font-ui" role="listitem">{s}</span>
          {i < studios.length - 1 && (
            <span class="studio-sep" aria-hidden="true">·</span>
          )}
        </>
      ))}
    </div>
  </div>
</section>

<!-- ═══════════════════ CTA ══════════════════════════════════════════════ -->
<section class="cta-section" data-section>
  <div class="section-inner cta-inner">
    <div data-card-reveal style="--card-delay:0ms">
      <h2 class="cta-headline font-gothic">
        Let's make something worth<br />playing<span class="accent-dot">.</span>
      </h2>
      <p class="cta-body font-body">
        Open to Lead / Senior LD and Game Designer opportunities. Remote-friendly. Portfolio work available on request.
      </p>
      <div class="cta-actions">
        <a href="/contact" class="btn-primary">GET IN TOUCH →</a>
        <a href="/cv/stefan-malinovic-portfolio.pdf" target="_blank" rel="noopener" class="btn-secondary">DOWNLOAD CV</a>
      </div>
    </div>
  </div>
</section>

</Layout>

<script>
  // ── Scroll reveal ───────────────────────────────────────────────────────
  const sectionObs = new IntersectionObserver(
    (entries) => entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('in-view'); sectionObs.unobserve(e.target); }
    }),
    { threshold: 0.08 }
  );
  document.querySelectorAll('[data-section]').forEach(el => sectionObs.observe(el));

  const cardObs = new IntersectionObserver(
    (entries) => entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('card-visible'); cardObs.unobserve(e.target); }
    }),
    { threshold: 0.06 }
  );
  document.querySelectorAll('[data-card-reveal]').forEach(el => cardObs.observe(el));
</script>

<style>
/* ── Shared section chrome ───────────────────────────────────────────────── */
.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding-bottom: 1.5rem;
  border-bottom: 2px solid #1B1918;
  margin-bottom: 2.5rem;
}
.issue-label {
  font-family: 'Oswald', sans-serif;
  font-size: 0.6rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: #5D5954;
}

/* Scroll reveal — section level */
[data-section] .section-head,
[data-section] .intro-eyebrow,
[data-section] .intro-title,
[data-section] .intro-para,
[data-section] .intro-ctas,
[data-section] .studios-eyebrow,
[data-section] .studios-row,
[data-section] .cta-headline,
[data-section] .cta-body,
[data-section] .cta-actions,
[data-section] .lang-block {
  opacity: 0;
  transform: translateY(18px);
  transition: opacity 0.6s ease, transform 0.6s ease;
}

[data-section].in-view .intro-eyebrow  { opacity: 1; transform: translateY(0); }
[data-section].in-view .intro-title    { opacity: 1; transform: translateY(0); transition-delay: 0.08s; }
[data-section].in-view .intro-para     { opacity: 1; transform: translateY(0); transition-delay: 0.16s; }
[data-section].in-view .intro-ctas     { opacity: 1; transform: translateY(0); transition-delay: 0.24s; }
[data-section].in-view .section-head   { opacity: 1; transform: translateY(0); }
[data-section].in-view .studios-eyebrow{ opacity: 1; transform: translateY(0); }
[data-section].in-view .studios-row    { opacity: 1; transform: translateY(0); transition-delay: 0.1s; }
[data-section].in-view .cta-headline  { opacity: 1; transform: translateY(0); }
[data-section].in-view .cta-body      { opacity: 1; transform: translateY(0); transition-delay: 0.1s; }
[data-section].in-view .cta-actions   { opacity: 1; transform: translateY(0); transition-delay: 0.2s; }
[data-section].in-view .lang-block    { opacity: 1; transform: translateY(0); transition-delay: 0.28s; }

/* Card stagger */
[data-card-reveal] {
  opacity: 0;
  transform: translateY(32px);
  transition: opacity 0.55s ease var(--card-delay, 0ms), transform 0.55s ease var(--card-delay, 0ms);
}
[data-card-reveal].card-visible { opacity: 1; transform: translateY(0); }

/* ── Intro ───────────────────────────────────────────────────────────────── */
.intro-section {
  padding: 5rem 0 4rem;
  border-bottom: 1px solid #1B1918;
  position: relative;
  overflow: hidden;
}

.intro-section::before {
  content: 'STEFAN';
  position: absolute;
  right: -1rem;
  bottom: -1rem;
  font-family: 'Anton', Impact, sans-serif;
  font-size: clamp(5rem, 15vw, 13rem);
  color: #1B1918;
  line-height: 1;
  pointer-events: none;
  user-select: none;
  z-index: 0;
  letter-spacing: -0.04em;
}

.intro-inner {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 4rem;
  align-items: center;
  position: relative;
  z-index: 1;
}

.intro-eyebrow {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1.25rem;
}
.eyebrow-line {
  display: block;
  width: 32px;
  height: 2px;
  background: #BB3F2F;
  flex-shrink: 0;
}
.eyebrow-label {
  font-family: 'Oswald', sans-serif;
  font-weight: 700;
  font-size: 0.65rem;
  letter-spacing: 0.2em;
